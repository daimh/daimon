#!/usr/bin/python
#Author Manhong Dai, MNI, U of Michigan
import sys, subprocess, argparse, time, re
def err_exit(msg):
	print(msg, file=sys.stderr)
	exit(1)

class Task():
	option = None

class DfCheck(Task):
	option = 'd'
	helpmsg = 'A list of mountpoints and threshold'
	metavar = "MOUNTPOINTS:PCT-THRESHOLD(:SIZE-THRESHOLD-IN-GB)"
	def __init__(self, prefix, param):
		fs = param.split(':')
		self.check = [int(s) for s in fs[1:]]
		self.cmds = []
		if prefix.endswith(':0'): self.cmds.append(f'echo -e "{prefix}:\t"BEGIN')
		for mp in fs[0].split(','):
			if mp == 'TMPFS':
				self.cmds.append(f'df -Pt tmpfs |tail -n +2 | grep -v /run/user/ | sed -e "s/^/{prefix}:\t/"')
			else:
				self.cmds.append(f'mountpoint {mp} &> /dev/null && df -P {mp} | tail -n +2 | sed -e "s/^/{prefix}:\t/"')
	def getln(self, ln):
		if ln == 'BEGIN':
			return f'Size\tAvail\tUsed%\tThreshold%\tMounted on\tFilesystem'
		fs = ln.split()
		size = int(fs[1])/1048576
		used = int(fs[4][:-1])
		avail = int(fs[3])/1048576
		if used >= self.check[0] or (len(self.check) == 2 and size < self.check[1]):
			return '%dG\t%dG\t%d%%\t%d%%\t%s\t%s' % (size, avail, used, self.check[0], fs[5], fs[0])
		if len(self.check) == 1:
			return '%dG\tOK\t\t\t%s\t%s' % (size, fs[5], fs[0])
		if len(self.check) == 2:
			return 'OK\tOK\t\t\t%s\t%s' % ( fs[5], fs[0])
		err_exit('ERR-107: %s' % ln)

class SmartCheck(Task):
	option = 's'
	helpmsg = 'A list of drives, smart status of which will be checked. IGNORE_KEYWORDS in smartctl output will be skipped, "Local Time" is always ignred. Both DRIVES and KEYWORDS is comma separated'
	metavar = 'DRIVES:IGNORE_KEYWORDS'
	def __init__(self, prefix, param):
		fs = param.split(':')
		self.check = ['Local Time is']
		if len(fs) > 1: self.check += fs[1].split(',')
		self.check = list(set(self.check))
		self.cmds = []
		for drv in fs[0].split(','):
			self.cmds.append(f'smartctl -iH /dev/{drv} | tail -n +4 | sed -e "s/^/{prefix}:\t{drv}:\t/"')
	def getln(self, ln):
		for key in self.check:
			if ln[ln.index(':\t')+2:].startswith(f'{key}:'): return
		return ln

class Dmesg(Task):
	option = 'm'
	helpmsg = 'Search a list of KEYWORDS in dmesg output'
	metavar = 'KEYWORDS'
	def __init__(self, prefix, param):
		self.cmds = [f'dmesg | grep -E "{param}" | sed -e "s/^/{prefix}:\t/"']
	def getln(self, ln):
		return ln

class LoadCheck(Task):
	option = 'l'
	helpmsg ='Print uptime if any of the three load average is greater than +F or less than -F. If it is specified multiple times and any of them is satisifed, it will print uptime'
	metavar = '±THRESHOLD'
	def __init__(self, prefix, param):
		self.check = float(param)
		self.cmds = [f'uptime | sed -e "s/^/{prefix}:\t/"']
	def getln(self, ln):
		loads = [float(s) for s in ln.split('load average: ')[1].split(', ')]
		if self.check >= 0:
			if max(loads) >= self.check:
				return f'+{self.check}'
		elif min(loads) <= -self.check:
				return f'{self.check}'

class Command(Task):
	option = 'c'
	helpmsg ='commands to be run on the target'
	metavar = 'COMMAND'
	def __init__(self, prefix, param):
		self.cmds = [f'{param} | sed -e "s/^/{prefix}:\t/"' ]
	def getln(self, ln):
		return ln

class Temperature(Task):
	option = 't'
	helpmsg ="Threshold of the hottest read in sensors output"
	metavar = 'TEMPERATURE'
	def __init__(self, prefix, param):
		self.check = int(param)
		self.cmds = [f"sensors | sed -e 's/^/{prefix}:\t/'"]
	def getln(self, ln):
		search = re.compile('\+[0-9]+\.[0-9]').search(ln)
		if search is None: return
		if int(float(search.group(0)[1:])) <= self.check: return
		return ln

class Stat(Task):
	helpmsg = "stat permission and owner of FILES"
	metavar = 'FILES'
	def __init__(self, prefix, param):
		self.cmds = []
		for fl in param.split(','):
			self.cmds.append(f"stat -c '%A\t%i\t%U\t%G\t%n' {fl} | sed -e 's/^/{prefix}:\t/'")
	def getln(self, ln):
		return ln

class Md5sum(Task):
	helpmsg = "md5sum of FILES"
	metavar = 'FILES'
	FILES = ['.ssh/authorized_keys,/etc/passwd,/etc/ssh/sshd_config']
	def __init__(self, prefix, param):
		self.cmds = []
		for fl in param.split(','):
			self.cmds.append(f"md5sum {fl} 2>&1 | sed -e 's/^/{prefix}:\t/'")
	def getln(self, ln):
		return ln

class AllowedTimeOffset(Task):
	option = 'o'
	helpmsg = "allowed time offset in seconds"
	metavar = 'SECONDS'
	def __init__(self, prefix, param):
		self.check = int(param)
		now = int(time.time())
		self.cmds = [
			f'date "+%s - {now}" | sed -e "s/^/{prefix}:\t/"',
		]
	def getln(self, ln):
		fs = [int(s) for s in ln.split(' - ')]
		diff = fs[0] - fs[1]
		if diff < self.check: return
		return f'{diff}'

class Sysinfo(Task):
	def __init__(self, prefix, param):
		self.cmds = [
			f'(uname -a; head -n 1 /proc/meminfo) | sed -e "s/^/{prefix}:\t/"',
			f'[ -f /proc/mdstat ] && cat /proc/mdstat | sed -e "s/^/{prefix}:\tMDSTAT:\t/"',
			f'[ -f /proc/drbd ] && grep " cs:" /proc/drbd | sed -e "s/^/{prefix}:\tDRBD:\t/"',
			f'ip a | grep -v valid_lft | sed -e "s/^/{prefix}:\tIP:\t/"',
			f'if which ipmitool &>/dev/null; then ipmitool sdr 2>&1 | cut -d "|" -f 1,3 |grep -vEw "ok$|ns$" | sed -e "s/^/{prefix}:\tIPMITOOL:\t/"; fi',
			f'if which lvdisplay &> /dev/null; then lvdisplay -C 2>&1 | sed -e "s/^/{prefix}:\tLVDISPLAY:\t/"; fi',
		]
	def getln(self, ln):
		if ln.startswith('MDSTAT:\t      bitmap:'): return
		return ln

class Areca(Task):
	helpmsg = "areca cli64 for Areca raid card"
	metavar = 'TEMPERATURE or TEMPERATURE:60-bay'
	def __init__(self, prefix, param):
		fs = param.split(':')
		if len(fs) != 2 or fs[0][-1] != 'C':
			err_exit('ERR-106: areca should be followed by a temperature alert threshold and number of cards, such as "--areca 50C:2"')
		self.temperature = int(fs[0][:-1])
		cli64 = '%s\nquit' % '\n'.join(['set curctrl=%d\nhw info\nvsf info\ndisk info' % (idx+1) for idx in range(int(fs[1]))])
		self.cmds = [f'echo -e "{cli64}" | cli64 |col -b | sed -e "s/^/{prefix}:\t/"']
		self.printit = True
	def getln(self, ln):
		if "Ctrl Temperature" in ln or "Controller Temp." in ln:
			idx = ln.rindex(': ') + 2
			if int(ln[idx:ln.index(' ', idx)]) >= self.temperature:
				return ln
			return
		if ln.startswith('[Controller H/W Monitor]') or ln.startswith('CLI> The Hardware Monitor Information'):
			self.printit = False
			return
		if ln.startswith('CLI>'):
			self.printit = True
			return ln
		if self.printit:
			return ln

class Megacli(Task):
	helpmsg = "megacli for LSI raid card"
	metavar = 'TEMPERATURE'
	def __init__(self, prefix, param):
		if param[-1] != 'C': err_exit('ERR-105: --megacli needs a temperature alert threshold endswith "C", such as "--megacli 50C"')
		self.temperature = int(param[:-1])
		self.cmds = [
			f'/opt/MegaRAID/MegaCli/MegaCli64 -LdPdInfo -aALL | sed -e "s/^/{prefix}:\t/"',
		]
	def getln(self, ln):
		if not ln.startswith('Drive Temperature :') or int(ln[19:ln.index('C', 19)]) >= self.temperature:
			return ln

class Storcli(Task):
	helpmsg = "storcli for LSI raid card"
	metavar = 'TEMPERATURE or TEMPERATURE:60-bay'
	def __init__(self, prefix, param):
		self.hdds = []
		self.formfactor = None
		fs = param.split(':')
		if fs[0][-1] != 'C': err_exit('ERR-104: --storcli needs a temperature alert threshold endswith "C", optionally followed by a form factor, such as "60-bay", such as "--storcli 50C", or "--storcli 50C:60-bay"')
		self.temperature = int(fs[0][:-1])
		self.formfactor = fs[1] if len(fs) > 1 else None
		self.cmds = [
			f'/opt/MegaRAID/storcli/storcli /call show all| grep -iv "Date/Time" | sed -e "s/^/{prefix}:\t/"',
			f'/opt/MegaRAID/storcli/storcli /call /eall /sall show all | sed -e "s/^/{prefix}:\t/"'
		]
		self.ln_bt_check = 0
	def __del__(self):
		re_slot = re.compile('Drive /c([0-9]+)/e([0-9]+)/s([0-9]+) Device attributes :')
		sns_each_card_enc = {}
		for hd in self.hdds:
			if len(hd) != 3: raise Exception('ERR-103')
			mt = re_slot.match(hd[0])
			if mt is None: raise Exception('ERR-102')
			s_card, s_enc, s_slot = int(mt.group(1)), int(mt.group(2)), int(mt.group(3))
			s_sn = hd[1].split(' = ')[1].strip()
			s_sz = hd[2].split(' = ')[1]
			s_sz = s_sz[:s_sz.index(' [')]
			sns_each_card_enc.setdefault(f'/c{s_card}/e{s_enc}', {})[s_slot] = (s_sn, s_sz)
		for card_enc, slot_sns in sns_each_card_enc.items():
			for sn in sorted(slot_sns.items()):
				print(f'{card_enc}/s{sn[0]}', sn[1][0], sn[1][1], sep='\t')
		if self.formfactor == '60-bay':
			for card_enc, slot_sns in sns_each_card_enc.items():
				print(f'#{card_enc}, ▲: Left/Right, ▼: Right/Left, ◄: Front/Back, ►: Back/Front')
				if len(slot_sns) != 20:
					print('no 20 drives')
					continue
				slot_sns = [sn[0] for sl, sn in sorted(slot_sns.items())]
				for row in range(5):
					print('\t'.join([slot_sns[col*5 + row] for col in (range(4)) if col*5 + row < len(slot_sns)]))
	def getln(self, ln):
		if ln.startswith('Drive /c') and ln.endswith(' Device attributes :'):
			self.hdds.append([ln])
		elif ln.startswith('SN = ') or ln.startswith('Raw size = '):
			self.hdds[-1].append(ln)
		if ln.startswith('Next Patrol Read launch = '): return
		if ln.startswith('Next Consistency check launch = '): return
		if ln.startswith('Next Battery Learn = '): return
		if ln.startswith('ROC temperature(Degree Celsius) = '): return
		if ln.startswith('iBBU '):
			ln =' '.join(ln.split()[:2])
			return ln
		if ln.startswith('Drive Temperature ='):
			if 'N/A' in ln or 'C' not in ln or int(ln.split('=')[1].split('C')[0]) >= self.temperature:
				return ln
			return
		if ln.startswith('CVPM0'):
			search = re.compile(' [0-9]+C ').search(ln)
			if search is not None:
				tmp  = int(search.group(0)[1:-2])
				if tmp <= self.temperature: ln = ln.replace(search.group(0), ' OK ')
				if tmp <= self.temperature: ln = ln[:search.span()[0]] + ' OK'
			return ln
		if re.compile('.* [DG]HS .* [DTU]  -    $').search(ln) is not None:
			return ln[:-8] + '#  -    '
		if re.compile('.* [DG]HS .* [DTU]  $').search(ln) is not None:
			return ln[:-3] + '#  '
		if self.ln_bt_check == 0 and ln.startswith('DG Arr Row EID:Slot DID Type '):
			self.ln_bt_check = 1
			return ln
		if self.ln_bt_check == 1:
			if not ln.startswith('-------'): err_exit('ERR-108: unexpected line in storcli')
			self.ln_bt_check = 2
			return ln
		if self.ln_bt_check == 2:
			if ln.startswith('-------'):
				self.ln_bt_check = 0
			else:
				ln = ln.replace(' Optl  Y ', ' Optl  # ')
				ln = ln.replace(' Optl  N ', ' Optl  # ')
				ln = ln.replace(' Onln  Y ', ' Onln  # ')
				ln = ln.replace(' Onln  N ', ' Onln  # ')
			return ln
		return ln
				
def get_args():
	parser = argparse.ArgumentParser()
	parser.add_argument("host", help="host", metavar="HOST")
	parser.add_argument("-p", "--port", type=int, help="Port number of the linux target", metavar="PORT", default=22)
	for cls in Task.__subclasses__():
		if cls.__name__.lower() == 'sysinfo': continue
		if cls.option:
			parser.add_argument(f"-{cls.option}", f"--{cls.__name__.lower()}", help=cls.helpmsg, metavar=cls.metavar, action='append')
		else:
			parser.add_argument(f"--{cls.__name__.lower()}", help=cls.helpmsg, metavar=cls.metavar, action='append')
#	parser.add_argument("-g", "--gluster", help="check gluster mount", metavar="GLUSTER")
#	parser.add_argument("-L", "--logging", help="logging to /var/log/dm-linux", action='store_true')
	return parser.parse_args()

def set_args_default(args):
	if args.md5sum is None:
		args.md5sum = Md5sum.FILES
	else:
		args.md5sum = Md5sum.FILES + args.md5sum
	if args.allowedtimeoffset is None:
		args.allowedtimeoffset = ['10']

def main():
	args = get_args()
	set_args_default(args)
	tasks = {}
	for cls in Task.__subclasses__():
		option = cls.__name__.lower()
		if option == 'sysinfo':
			params = [None]
		else:
			params = getattr(args, option)
		if params is None: continue
		for idx in range(len(params)):
			prefix = f'{option}:{idx}'.upper()
			tasks[prefix] = cls(prefix, params[idx])
	cmds = []
	for prefix in sorted(tasks.keys()):
		cmds += tasks[prefix].cmds
	p = subprocess.Popen(["ssh", "-o", "loglevel=error", "-np", str(args.port), args.host, "; ".join(cmds)], stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
	sshout = p.communicate()[0].decode('utf-8', 'ignore').rstrip()
	if p.returncode != 0:
		err_exit(f'ERR-101: ssh failed! output is\n{sshout}')
	for ln in sshout.split('\n'):
		idx = ln.find(':\t')
		if idx == -1: continue
		prefix = ln[:idx]
		ln = tasks[prefix].getln(ln[len(prefix)+2:])
		if ln is None: continue
		print(f'{prefix}:\t{ln}')

if __name__ == '__main__': main()
