#!/usr/bin/env bash
set -euf
set -o pipefail
trap "exit 1" TERM
function helpme {
	if [ $# -gt 0 ]
	then
		echo -e "$1" 1>&2
	else
		grep '#' /proc/$$/fd/255 | sed -n '/^#HELPME_START/,/^#HELPME_END/p' | grep -v "^#HELPME_" | sed -e "s/#//" | tr -s '\t' 1>&2 #20220313
	fi
	PGID=$(cut -d ' ' -f 5 /proc/$$/stat)
	kill -s TERM -- -$PGID
}
CONFIG=/etc/daimon.conf
. $CONFIG || helpme "ERR-100: Configuration file $CONFIG is missing"
EMAIL=""
TASK=""
let COUNT=1
OPT_SHORT="hvt:m:n:"
OPT_LONG="help,version,task:,mail:,count:"
OPTS=$(getopt -o $OPT_SHORT --long $OPT_LONG -n "$(basename $0)" -- "$@")
eval set -- "$OPTS"
while [ $# -gt 0 ]
do
	case "$1" in
#HELPME_START
#SYNOPSIS
#	daimon [OPTION]... -- CMD
#EXAMPLE
#	daimon -t linux/host-a -- dm-linux host-a -d 50
#DESCRIPTION
		-h | --help)	#print help information
			helpme ;;
		--version)	#print version
			helpme 20220312 ;;
		-v )	#verbose output
			set -x
			shift ;;
		-t | --task)	#name of a sub-directory under $DAIMON_HOME/var
			TASK=$2
			shift 2 ;;
		-m | --mail)	#email addresses the alerts will be sent to, seperated by comma
			EMAIL=$(echo $2 | sed -e "s/,/ /g")
			shift 2 ;;
		-n | --count)	#send up to COUNT alerts for a new incident, default 1
			let COUNT=$2 || helpme "ERR-101: -n needs a positive number"
			shift 2 ;;
		--)
			shift 1 ;;
		*)
			break ;;
#AUTHOR
#	Manhong Dai, MNI, U of Michigan
#COPYRIGHT
#	Copyright © 2002-2022 University of Michigan. License GPLv3+: GNU
#	GPL version 3 or later <https://gnu.org/licenses/gpl.html>.
#	This is free software: you are free to change and redistribute it.
#	There is NO WARRANTY, to the extent permitted by law.
#HELPME_END
	esac
done
if [ "$DAIMON_EMAIL" != "NO" ]
then
	set +u
	[ -n "$EMAIL" ] || EMAIL=$MAILTO
	[ -n "$EMAIL" ] || EMAIL=$USER
	set -u
	[ -n "$EMAIL" ] || helpme "ERR-102: -m needs an email address"
fi
CMD="$@"
[ -n "$DAIMON_HOME" ] || helpme "ERR-103: missing environment variable DAIMON_HOME in Configuration file $CONFIG"
[ -d "$DAIMON_HOME" ] || helpme "ERR-104: $DAIMON_HOME is not a directory"
[ -n "$TASK" ] || helpme "ERR-105: TASK is missing"
ID=$DAIMON_HOME/var/$TASK
[ -t 1 ] || sleep $[ $RANDOM%10 ]
if [ ! -f $ID/out-standard ]
then
	mkdir -p $ID
	rm -f $ID/diff-count
	if ! timeout 60 bash -c "$CMD" &> $ID/out-current
	then 
		cat $ID/out-current
		echo 99999 > $ID/diff-count
		helpme "ERR-106: INITIALIZING FAILED FOR $TASK"
	fi
	mv $ID/out-current $ID/out-standard
	cat $ID/out-standard 
	[ "$DAIMON_EMAIL" = "NO" ] || cat $ID/out-standard | mail -s "$TASK is initalized successfully. If the command output is not right, let admins know it" $EMAIL
else
	if fuser $ID/lock &> /dev/null
	then
		fuser -k $ID/lock &> /dev/null
		echo "ERR-002: A previous $TASK is still running, it is killed" >> $ID/out-current
	else
		rm -f $ID/out-current
	fi
	(
		if ! flock -xn 99
		then
			[ "$DAIMON_EMAIL" = "NO" ] || echo | mail -s "$TASK ERR-001: flock failed" $EMAIL
		else
			set +e
			timeout 60 bash -c "$CMD" >> $ID/out-current 2>> $ID/out-current
			let RTN=$?
			set -e
			if [ $RTN -eq 124 -o $RTN -eq 125 -o $RTN -eq 126 -o $RTN -eq 127 -o $RTN -eq 137 ]
			then
				echo "timeout returned $RTN" >> $ID/out-current
			elif [ $RTN -ne 0 ]
			then
				echo "sub-command returned $RTN" >> $ID/out-current
			fi
			set +f
			for STD in $(cd $ID && ls out-standard.* 2>/dev/null) out-standard
			do
				if diff $ID/out-current $ID/$STD > $ID/diff-$STD 2> /dev/null
				then
					break
				fi
			done
			cd $ID && mv $(ls -rS diff-out-standard* | head -n 1) diff-current && rm -f diff-out-standard* 2> /dev/null
			set -f
			if [ -f $ID/diff-count ]
			then
				let FAILED_PRV=$(cat $ID/diff-count) || :
			else
				let FAILED_PRV=0 || :
			fi
			if [ -s $ID/diff-current ]
			then
				if [ $FAILED_PRV -gt 0 ] && diff -q $ID/diff-current $ID/diff-previous &> /dev/null
				then
					let FAILED_CUR=$FAILED_PRV+1
				else
					let FAILED_CUR=1
					cp $ID/diff-current $ID/diff-previous
					cp $ID/diff-current $ID/history-$(date +%FT%T)-abnm
				fi
				echo $FAILED_CUR > $ID/diff-count
				if [ $FAILED_CUR -le $COUNT ]
				then
					if [ $FAILED_CUR -eq $COUNT -a $COUNT -gt 1 ]
					then
						SUBJECT="$TASK is detected (FINAL ALERT)"
					else
						SUBJECT="$TASK is detected"
					fi
					[ "$DAIMON_EMAIL" = "NO" ] || cat $ID/diff-current | strings -n 1 2>&1 | mail -s "$SUBJECT" $EMAIL
				fi
			else
				if [ $FAILED_PRV -gt 0 ]
				then
					[ "$DAIMON_EMAIL" = "NO" ] || cat $ID/out-current | strings -n 1 2>&1 | mail -s "$TASK is back to normal" $EMAIL
					echo $FAILED_PRV > $ID/history-$(date +%FT%T)-norm
				fi
				echo 0 > $ID/diff-count
				rm -f $ID/diff-previous
			fi
		fi 
	) 99> $ID/lock
fi

