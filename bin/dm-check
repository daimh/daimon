#!/usr/bin/env bash
set -euf
set -o pipefail
trap "exit 1" TERM
function helpme {
	if [ $# -gt 0 ]
	then
		echo -e "$1" 1>&2
	else
		grep '#' /proc/$$/fd/255 | sed -n '/^#HELPME_START/,/^#HELPME_END/p' | grep -v "^#HELPME_" | sed -e "s/#//" | tr -s '\t' 1>&2 #20220313
	fi
	PGID=$(cut -d ' ' -f 5 /proc/$$/stat)
	kill -s TERM -- -$PGID
}
ALL=NO
REMOVE=NO
OPT_SHORT="hvar"
OPT_LONG="help,version,all,remove"
OPTS=$(getopt -o $OPT_SHORT --long $OPT_LONG -n "$(basename $0)" -- "$@")
eval set -- "$OPTS"
while [ $# -gt 0 ]
do
	case "$1" in
#HELPME_START
#SYNOPSIS
#	dm-check [OPTION]... 
#EXAMPLE
#	cd /opt/daimon/var; dm-check
#DESCRIPTION
		-h | --help)	#print help information
			helpme ;;
		--version)	#print version
			helpme 20220312 ;;
		-v )	#verbose output
			set -x
			shift ;;
		-a | --all)	#check all tasks, regardless of current directory
			ALL=YES
			shift ;;
		-r | --remove)	#remove all history files under current directory
			REMOVE=YES
			shift ;;
		--)
			shift
			break ;;
		*)
			break ;;
#AUTHOR
#	Manhong Dai, MNI, U of Michigan
#COPYRIGHT
#	Copyright © 2002-2022 University of Michigan. License GPLv3+: GNU
#	GPL version 3 or later <https://gnu.org/licenses/gpl.html>.
#	This is free software: you are free to change and redistribute it.
#	There is NO WARRANTY, to the extent permitted by law.
#HELPME_END
	esac
done
CONFIG=/etc/daimon.conf
. $CONFIG || helpme "ERR-100: Configuration file $CONFIG is missing"
[ -n "$DAIMON_HOME" ] || helpme "ERR-101: DAIMON_HOME is not defined in the configuration file $CONFIG"
if [ "$ALL" = "YES" ]
then
	cd $DAIMON_HOME/var
elif [[ $PWD != $DAIMON_HOME/var* ]]
then
	helpme "ERR-102: cd to any directory under $DAIMON_HOME/var at first, or use '-a'"
fi
if [ "$REMOVE" = "YES" ]
then
	find . -type f -name "history-*" -print -exec rm {} \;
fi
CUT=$(echo $DAIMON_HOME/var/ | wc -c)
for f in $(find $* -type d | sort)
do
	[ -f $f/lock ] || continue
	(
		if ! flock -xn 99 
		then
			clear
			read -n 1 -r -p "$f is locked, press any key to continue" 
			exit
		fi
		[ ! -f $f/diff-count ] && exit
		[ -f $f/diff-count ] && diff -q $f/diff-count <(echo 0) > /dev/null && exit
		[ ! -f $f/out-current -o ! -f $f/out-standard ] && exit
		[ -f $f/diff-current -a ! -s $f/diff-current ] && exit 
		clear
		set +o pipefail
		diff $f/out-current $f/out-standard | less -FXP "$(realpath -s $f | cut -c $CUT-)"
		set -o pipefail
		while :
		do
			read -n 1 -r -p "Standardize '$(realpath -s $f | cut -c $CUT-)'? [y/nq]" ynq
			case "$ynq" in
				Y|y )
					mv $f/out-standard $f/history-$(date +%FT%T)-standard
					cp $f/out-current $f/out-standard 
					echo 0 > $f/diff-count
					break;;
				N|n|q )
					break;;
				* )
					echo "Please answer y, n or q";;
			esac
		done
		echo
	) 99> $f/lock
done
