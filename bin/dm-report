#!/usr/bin/env bash
#Author Manhong Dai, MNI, U of Michigan
set -euf
set -o pipefail
trap "exit 1" TERM
function helpme {
	if [ $# -gt 0 ]
	then
		echo -e "$1" 1>&2
	else
		grep '#' /proc/$$/fd/255 | sed -n '/^#HELPME_START/,/^#HELPME_END/p' | grep -v "^#HELPME_" | sed -e "s/#//" | tr -s '\t' 1>&2 #20220313
	fi
	PGID=$(cut -d ' ' -f 5 /proc/$$/stat)
	kill -s TERM -- -$PGID
}
ALL=NO
OPT_SHORT="hva"
OPT_LONG="help,version,all"
OPTS=$(getopt -o $OPT_SHORT --long $OPT_LONG -n "$(basename $0)" -- "$@")
eval set -- "$OPTS"
while [ $# -gt 0 ]
do
	case "$1" in
#HELPME_START
#SYNOPSIS
#	dm-report [OPTION]... 
#EXAMPLE
#	dm-report
#DESCRIPTION
		-h | --help)	#print help information
			helpme ;;
		--version)	#print version
			helpme 20220312 ;;
		-v )	#verbose output
			set -x
			shift ;;
		-a | --all)	#report all tasks, regardless of current directory
			ALL=YES
			shift ;;
		--)
			shift 1 ;;
		*)
			break ;;
#AUTHOR
#	Manhong Dai, MNI, U of Michigan
#COPYRIGHT
#	Copyright © 2002-2022 University of Michigan. License GPLv3+: GNU
#	GPL version 3 or later <https://gnu.org/licenses/gpl.html>.
#	This is free software: you are free to change and redistribute it.
#	There is NO WARRANTY, to the extent permitted by law.
#HELPME_END
	esac
done
CONFIG=/etc/daimon.conf
. $CONFIG || helpme "ERR-100: Configuration file $CONFIG is missing"
[ -n "$DAIMON_HOME" ] || helpme "ERR-101: DAIMON_HOME is not defined in the configuration file $CONFIG"
if [ "$ALL" = "YES" ]
then
	cd $DAIMON_HOME/var
elif [[ $PWD != $DAIMON_HOME/var* ]]
then
	helpme "ERR-102: cd to any directory under $DAIMON_HOME/var at first, or use '-a'"
fi
let TS=$(date +%s)
HEADER="Count\tTime\tTask"
find . -type f -name diff_count | sort | while read F;
do
	diff -q $F <(echo 0) > /dev/null && continue 
	D=$(echo $F|cut -c 3- |rev | cut -c 12-|rev)
	if [ -f $D/diff_previous ]
	then
		let T=$TS-$(ls -l --time-style='+%s' $D/diff_previous | cut -d " " -f 6)
		if [[ T -ge 86400 ]]
		then
			((T=T/86400))
			T="${T}d"
		elif [[ T -ge 3600 ]]
		then
			((T=T/3600))
			T="${T}h"
		elif [[ T -ge 60 ]]
		then
			((T=T/60))
			T="${T}m"
		else
			T="${T}s"
		fi
	else
		T=NA
	fi
	[ -z "$HEADER" ] || echo -e $HEADER && HEADER=""
	echo -e "$(cat $F)\t$T\t$D"
done 
