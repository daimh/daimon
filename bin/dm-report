#!/usr/bin/bash
#20210312 modification caused by daisync/etc/config change
#20200910 getopt
#20190204 NODE DEST when "no log found"
#20180604 time as first column
#20180127 sort daisync output
#20170824 running failed
#20170817 diff exclude.lst
#20170302 daisync is added
set -e
trap "exit 1" TERM
function helpme {
	if [[ "$1" != "" ]]
	then
		echo -e "$1" 1>&2
	else
		cat /proc/$$/fd/255 | sed -n '/^#HELPME_START/,/^#HELPME_END/p' | grep -v "^#HELPME_" | grep -e "	-\|^#" | grep -- "$(echo $OPT_SHORT | sed -e "s/://g" | sed -e "s/\(.\)/\t-\1 \\\|/g" | sed -e "s/$/^#$COMMAND\t\\\|^#[A-Z]/" )" | sed -e "s/^#$COMMAND\t/\t/; s/^#//" 1>&2
	fi
	PGID=$(cut -d ' ' -f 5 /proc/$$/stat)
	kill -s TERM -- -$PGID
}
OPT_SHORT="hv"
OPT_LONG="help,verbose"
OPTS=$(getopt -o $OPT_SHORT --long $OPT_LONG -n "$(basename $0)" -- "$@")
eval set -- "$OPTS"
while :
do
	case "$1" in
#HELPME_START
#SYNOPSIS:
#	dm-report [OPTION]... 
#EXAMPLE:
#	dm-report
		-h | --help)
			helpme ;;
		-v | --verbose)	#optional, verbose
			set -x
			shift ;;
		--)
			shift 1 ;;
		*)
			break ;;
#HELPME_END
	esac
done
CONFIG=/etc/daimon.conf
. $CONFIG || helpme "ERR-100: Configuration file $CONFIG is missing"
cd $DAIMON_HOME/var || helpme "ERR-101: DAIMON_HOME is not defined in the configuration file $CONFIG"
let TS=$(date +%s)
find . -type f -name diff_count | sort | while read F;
do
	diff -q $F <(echo 0) > /dev/null && continue 
	D=$(echo $F|cut -c 3- |rev | cut -c 12-|rev)
	if [ -f $D/diff_previous ]
	then
		let T=$TS-$(ls -l --time-style='+%s' $D/diff_previous | cut -d " " -f 6)
		if [[ T -ge 86400 ]]
		then
			((T=T/86400))
			T="${T}d"
		elif [[ T -ge 3600 ]]
		then
			((T=T/3600))
			T="${T}h"
		elif [[ T -ge 60 ]]
		then
			((T=T/60))
			T="${T}m"
		else
			T="${T}s"
		fi
	else
		T=NA
	fi
	echo -e "$(cat $F)\t$T\t$D"
done 
